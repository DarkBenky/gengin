{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: main.py (conda base)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/llmOpt/main.py",
      "python": "/home/user/anaconda3/bin/python",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/llmOpt"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "/home/user/Desktop/gengin",
      "program": "/home/user/Desktop/gengin/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}